{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "radianite-site",
  "main": "./scripts/radianite-site-worker.ts",
  "compatibility_date": "2026-07-15",
  "preview_urls": false,
  "workers_dev": false,
  "routes": [
    {
      "pattern": "get.radcolor.dev",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./docs",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
