{
  "name": "radianite",
  "private": true,
  "version": "0.2.0",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint src-ui tests *.config.ts eslint.config.js svelte.config.js",
    "format": "prettier --write \"src-ui/**/*.{svelte,ts,css,json}\" \"tests/**/*.{svelte,ts,css,json}\" \"*.{js,ts,json}\"",
    "format:check": "prettier --check \"src-ui/**/*.{svelte,ts,css,json}\" \"tests/**/*.{svelte,ts,css,json}\" \"*.{js,ts,json}\"",
    "build": "bun run check && vite build",
    "locales:check": "node scripts/validate-locales.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:visual": "playwright test",
    "benchmark:windows": "powershell -ExecutionPolicy Bypass -File scripts/benchmark-frontend.ps1",
    "benchmark:background": "node scripts/benchmark-background.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": "prettier --write"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/lexend": "^5.2.11",
    "@fontsource/source-code-pro": "^5.2.7",
    "@tabler/icons-svelte": "^3.44.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "i18next": "^25.10.10",
    "dompurify": "^3.2.6",
    "marked": "^16.0.0",
    "svelte-sonner": "^1.1.0",
    "tailwind-variants": "^3.2.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/svelte": "^5.4.2",
    "@types/pngjs": "^6.0.5",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.43.8",
    "svelte-check": "^4.3.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
